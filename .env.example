# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to GitHub — add ".env" to .gitignore.

# Printify — get from Printify dashboard > My Profile > Connections
PRINTIFY_API_TOKEN=your_printify_token_here
PRINTIFY_SHOP_ID=your_printify_shop_id_here

# Flutterwave — SECRET key only, from Flutterwave dashboard > Settings > API
# Never put the secret key in any frontend code. Backend only.
FLW_SECRET_KEY=your_flutterwave_secret_key_here

# Port for local testing (hosting providers set this automatically)
PORT=4000
